{% extends 'base.html.twig' %}


{% block body %}

	<!-- Navigation-->
	{% include 'tools/navigation.html.twig'  %}
	<!-- Header-->
	{% include 'tools/header.html.twig'  %}

	<!-- Section-->
	<div class="container">
		<hr/>


		<h1>Liste des Cliens</h1>

		<table class="table">
			<thead>
				<tr>
					<th>Id</th>
					<th>Nom</th>
                    <th>Prénom</th>
					<th>Revenus</th>

				</tr>
			</thead>
			<tbody>
				{% for  directeur in directeurs %}
					<tr>
                    <td>{{ directeur.id }}</td>
                    <td>{{ directeur.nom }}</td>
                    <td>{{ directeur.prenom }}</td>
                    <td>{{ directeur.revenus }}</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="8">Aucun Directeur
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
{% endblock %}
